    "express-rate-limit": "^7.4.0",
    "express-slow-down": "^2.0.3",
    "helmet": "^8.0.0",
    "jsdom": "^25.0.0",
    "meilisearch": "^0.44.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "sharp": "^0.34.5",
    "zod": "^3.23.0"
  },
