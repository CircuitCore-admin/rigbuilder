# ============================================================
# RigBuilder Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---- Application ----

# Runtime environment (development | production | test)
NODE_ENV=development

# Port the API server listens on
PORT=4000

# ---- Database ----

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://rigbuilder:changeme@localhost:5432/rigbuilder

# ---- Security ----

# Secret used to sign session cookies — must be at least 32 random characters
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-64-char-random-hex-string-here

# Secret used for CSRF token generation — must be at least 32 random characters
# Generate with: openssl rand -hex 32
CSRF_SECRET=replace-with-64-char-random-hex-string-here

# Optional AES-256-GCM key for encrypting marketplace payment details (32 bytes hex)
# Generate with: openssl rand -hex 32
MARKETPLACE_ENCRYPTION_KEY=

# ---- CORS ----

# Allowed frontend origin(s) — no trailing slash
CORS_ORIGIN=http://localhost:5173

# ---- Meilisearch ----

# Meilisearch instance URL (default: http://localhost:7700)
MEILISEARCH_URL=http://localhost:7700

# Meilisearch master key — required in production
# Generate with: openssl rand -hex 32
MEILISEARCH_API_KEY=changeme

# ---- Email (SMTP) ----

# SMTP server host
SMTP_HOST=smtp.gmail.com

# SMTP server port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP authentication username (usually your email address)
SMTP_USER=your-email@gmail.com

# SMTP authentication password (use an App Password for Gmail)
SMTP_PASS=your-app-password

# From address shown in outgoing emails
FROM_EMAIL=noreply@rigbuilder.com

# ---- Frontend ----

# Public URL of the frontend app — used in email links
APP_URL=http://localhost:5173

