// ============================================================================
// RigBuilder — Prisma Schema
// Spec-driven sim racing configurator platform
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum ProductCategory {
  COCKPIT
  WHEELBASE
  WHEEL_RIM
  PEDALS
  SHIFTER
  DISPLAY
  SEAT
  EXTRAS
}

enum ProductSubcategory {
  // Wheelbase
  DIRECT_DRIVE
  BELT_DRIVE
  GEAR_DRIVE
  // Pedals
  POTENTIOMETER
  LOAD_CELL
  HYDRAULIC
  // Shifter
  SEQUENTIAL
  H_PATTERN
  DUAL_MODE
  // Display
  MONITOR
  VR_HEADSET
  // Seat
  BUCKET
  GT_STYLE
  OEM
  // Extras
  BASS_SHAKER
  BUTTON_BOX
  HANDBRAKE
  KEYBOARD_TRAY
  CABLE_MANAGEMENT
}

enum Platform {
  PC
  PLAYSTATION
  XBOX
}

enum SpaceType {
  DESK
  DEDICATED_ROOM
  SHARED_ROOM
  COCKPIT_ONLY
}

enum Discipline {
  FORMULA
  GT
  RALLY
  DRIFT
  OVAL
  TRUCK
  MULTI
}

enum CompatibilityStatus {
  CONFIRMED
  REPORTED_ISSUE
  INCOMPATIBLE
}

enum CompatibilitySeverity {
  OK
  WARNING
  ERROR
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
  MANUFACTURER
  CREATOR
}

// ---------------------------------------------------------------------------
// Users
// ---------------------------------------------------------------------------

model User {
  id                String   @id @default(cuid())
  username          String   @unique
  email             String   @unique
  passwordHash      String   @map("password_hash")
  avatarUrl         String?  @map("avatar_url")
  bio               String?  @db.Text
  location          String?
  bannerUrl         String?  @map("banner_url")
  bannerColor       String?  @map("banner_color") @default("#1a1a2e")
  discordUsername   String?  @map("discord_username")
  profileVisibility String   @default("PUBLIC") @map("profile_visibility")
  role              UserRole @default(USER)
  isPro             Boolean  @default(false) @map("is_pro")
  reputation        Int      @default(0)
  pitCred           Int      @default(0) @map("pit_cred")
  sellerRating      Float?   @map("seller_rating")
  sellerReviewCount Int      @default(0) @map("seller_review_count")
  completedSales    Int      @default(0) @map("completed_sales")
  avgResponseMinutes Int?    @map("avg_response_minutes")
  emailVerified       Boolean   @default(false) @map("email_verified")
  emailVerifyToken    String?   @map("email_verify_token")
  emailVerifyExpiry   DateTime? @map("email_verify_expiry")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  sessions           Session[]
  builds             Build[]
  reviews            Review[]
  comments           Comment[]
  upvotes            Upvote[]
  compatibilityLinks CompatibilityLink[]
  wishlistItems      WishlistItem[]
  forumThreads       ForumThread[]
  forumReplies       ForumReply[]
  forumVotes         ForumVote[]
  threadVotes        ThreadVote[]
  guides             Guide[]
  badges             UserBadge[]
  threadFollows      ThreadFollower[]
  notifications      Notification[]

  marketplaceListings         MarketplaceListing[]
  marketplaceOffers           MarketplaceOffer[]
  marketplaceSentMessages     MarketplaceMessage[]      @relation("SentMessages")
  marketplaceReceivedMessages MarketplaceMessage[]      @relation("ReceivedMessages")
  marketplaceReports          MarketplaceReport[]
  marketplaceReviewsGiven     MarketplaceReview[]       @relation("ReviewerReviews")
  marketplaceReviewsReceived  MarketplaceReview[]       @relation("SellerReviews")
  marketplaceNotifications    MarketplaceNotification[]
  wishlistedListings          WishlistedListing[]       @relation("WishlistedListings")
  blockedUsers                UserBlock[]               @relation("BlockedUsers")
  blockedBy                   UserBlock[]               @relation("BlockedBy")

  @@index([username])
  @@index([email])
  @@index([role])
  @@index([createdAt(sort: Desc)])
  @@index([pitCred(sort: Desc)])
  @@index([sellerRating(sort: Desc)])
  @@map("users")
}

model Session {
  id        String   @id
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// ---------------------------------------------------------------------------
// Products
// ---------------------------------------------------------------------------

model Product {
  id             String              @id @default(cuid())
  name           String
  slug           String              @unique
  manufacturer   String
  category       ProductCategory
  subcategory    ProductSubcategory?
  specs          Json // JSONB — category-specific spec object
  releaseYear    Int?                @map("release_year")
  weight         Float? // kg
  dimensions     Json? // { length, width, height } in mm
  platforms      Platform[]          @default([])
  affiliateLinks Json?               @map("affiliate_links") // [{retailer, url, price, lastChecked}]
  images         String[]            @default([])
  avgRating      Float?              @map("avg_rating")
  reviewCount    Int                 @default(0) @map("review_count")
  buildCount     Int                 @default(0) @map("build_count")
  isVerified     Boolean             @default(false) @map("is_verified")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  buildParts          BuildPart[]
  reviews             Review[]
  compatibilityLinksA CompatibilityLink[]  @relation("ProductA")
  compatibilityLinksB CompatibilityLink[]  @relation("ProductB")
  upgradesFrom        UpgradePath[]        @relation("UpgradeFrom")
  upgradesTo          UpgradePath[]        @relation("UpgradeTo")
  wishlistItems       WishlistItem[]
  reviewsUpgradedFrom Review[]             @relation("UpgradedFrom")
  priceHistory        PriceHistory[]
  forumThreads        ForumThread[]
  marketplaceListings MarketplaceListing[]

  @@index([slug])
  @@index([category])
  @@index([manufacturer])
  @@index([category, manufacturer])
  @@index([avgRating(sort: Desc)])
  @@map("products")
}

// ---------------------------------------------------------------------------
// Builds
// ---------------------------------------------------------------------------

model Build {
  id          String       @id @default(cuid())
  userId      String       @map("user_id")
  name        String
  slug        String       @unique
  description String? // build story — sanitised HTML
  spaceType   SpaceType?   @map("space_type")
  disciplines Discipline[] @default([])
  platforms   Platform[]   @default([])
  totalCost   Float        @default(0) @map("total_cost")
  ratings     Json? // {satisfaction, comfort, immersion, difficulty, noise}
  images      String[]     @default([])
  upvoteCount Int          @default(0) @map("upvote_count")
  viewCount   Int          @default(0) @map("view_count")
  isPublic    Boolean      @default(true) @map("is_public")
  isFeatured  Boolean      @default(false) @map("is_featured")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  parts    BuildPart[]
  comments Comment[]
  upvotes  Upvote[]

  @@index([userId])
  @@index([slug])
  @@index([isPublic, upvoteCount(sort: Desc)])
  @@index([isPublic, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("builds")
}

model BuildPart {
  id           String          @id @default(cuid())
  buildId      String          @map("build_id")
  productId    String          @map("product_id")
  categorySlot ProductCategory @map("category_slot")
  pricePaid    Float?          @map("price_paid")
  notes        String?

  build   Build   @relation(fields: [buildId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([buildId, categorySlot])
  @@index([buildId])
  @@index([productId])
  @@map("build_parts")
}

// ---------------------------------------------------------------------------
// Reviews
// ---------------------------------------------------------------------------

model Review {
  id                    String   @id @default(cuid())
  userId                String   @map("user_id")
  productId             String   @map("product_id")
  ratingOverall         Float    @map("rating_overall") // 1-10
  subRatings            Json?    @map("sub_ratings") // {buildQuality, performance, value, noise, reliability}
  ownershipDuration     String?  @map("ownership_duration")
  upgradedFromProductId String?  @map("upgraded_from_product_id")
  pros                  String // sanitised
  cons                  String // sanitised
  wouldBuyAgain         Boolean  @map("would_buy_again")
  images                String[] @default([])
  isVerified            Boolean  @default(false) @map("is_verified")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  upgradedFrom Product? @relation("UpgradedFrom", fields: [upgradedFromProductId], references: [id])

  @@unique([userId, productId])
  @@index([productId, ratingOverall(sort: Desc)])
  @@index([userId])
  @@map("reviews")
}

// ---------------------------------------------------------------------------
// Compatibility & Upgrades
// ---------------------------------------------------------------------------

model CompatibilityLink {
  id                String                @id @default(cuid())
  productAId        String                @map("product_a_id")
  productBId        String                @map("product_b_id")
  status            CompatibilityStatus
  severity          CompatibilitySeverity @default(OK)
  reason            String?
  confirmedByUserId String?               @map("confirmed_by_user_id")
  createdAt         DateTime              @default(now()) @map("created_at")

  productA    Product @relation("ProductA", fields: [productAId], references: [id], onDelete: Cascade)
  productB    Product @relation("ProductB", fields: [productBId], references: [id], onDelete: Cascade)
  confirmedBy User?   @relation(fields: [confirmedByUserId], references: [id])

  @@unique([productAId, productBId])
  @@index([productAId])
  @@index([productBId])
  @@map("compatibility_links")
}

model UpgradePath {
  id                   String @id @default(cuid())
  fromProductId        String @map("from_product_id")
  toProductId          String @map("to_product_id")
  count                Int    @default(0)
  avgSatisfactionDelta Float  @default(0) @map("avg_satisfaction_delta")

  fromProduct Product @relation("UpgradeFrom", fields: [fromProductId], references: [id], onDelete: Cascade)
  toProduct   Product @relation("UpgradeTo", fields: [toProductId], references: [id], onDelete: Cascade)

  @@unique([fromProductId, toProductId])
  @@map("upgrade_paths")
}

// ---------------------------------------------------------------------------
// Social: Comments, Upvotes, Wishlist
// ---------------------------------------------------------------------------

model Comment {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  commentableType String   @map("commentable_type") // 'build' | 'product'
  commentableId   String   @map("commentable_id")
  body            String // sanitised
  parentId        String?  @map("parent_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  build   Build?    @relation(fields: [commentableId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("Replies", fields: [parentId], references: [id])
  replies Comment[] @relation("Replies")

  @@index([commentableType, commentableId])
  @@index([userId])
  @@map("comments")
}

model Upvote {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  upvoteableType String   @map("upvoteable_type") // 'build' | 'review'
  upvoteableId   String   @map("upvoteable_id")
  createdAt      DateTime @default(now()) @map("created_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  build Build? @relation(fields: [upvoteableId], references: [id], onDelete: Cascade)

  @@unique([userId, upvoteableType, upvoteableId])
  @@index([upvoteableType, upvoteableId])
  @@map("upvotes")
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlist_items")
}

// ---------------------------------------------------------------------------
// Phase 6 Enums
// ---------------------------------------------------------------------------

enum ForumCategory {
  BUILD_ADVICE
  DIY_MODS
  SHOWROOM
  TELEMETRY
  DEALS
  GENERAL
  TROUBLESHOOTING // legacy — kept for backward compatibility with existing threads
}

enum GuideCategory {
  BEGINNER
  BUYING
  MAINTENANCE
}

enum BadgeType {
  HELPFUL
  EXPERT
  VERIFIED_OWNER
  TOP_CONTRIBUTOR
}

// ---------------------------------------------------------------------------
// Phase 6: Price History
// ---------------------------------------------------------------------------

model PriceHistory {
  id         String   @id @default(cuid())
  productId  String   @map("product_id")
  retailer   String
  price      Float
  currency   String   @default("USD")
  recordedAt DateTime @default(now()) @map("recorded_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, recordedAt(sort: Desc)])
  @@index([productId, currency])
  @@map("price_history")
}

// ---------------------------------------------------------------------------
// Phase 6: Forum / Community Discussions
// ---------------------------------------------------------------------------

model ForumThread {
  id         String        @id @default(cuid())
  title      String
  slug       String        @unique
  body       String // sanitised markdown
  link       String? // optional external link
  category   ForumCategory
  userId     String        @map("user_id")
  productId  String?       @map("product_id") // optional link to a product
  isPinned   Boolean       @default(false) @map("is_pinned")
  isLocked   Boolean       @default(false) @map("is_locked")
  viewCount  Int           @default(0) @map("view_count")
  replyCount Int           @default(0) @map("reply_count")
  upvotes    Int           @default(0)
  downvotes  Int           @default(0)
  score      Int           @default(0)
  metadata   Json? // category-specific blueprint data (BOM, tools, deal status, etc.)
  imageUrls  String[]      @default([]) @map("image_urls") // gallery images for SHOWROOM
  isAnonymous Boolean      @default(false) @map("is_anonymous")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  replies     ForumReply[]
  followers   ThreadFollower[]
  threadVotes ThreadVote[]

  @@index([category, createdAt(sort: Desc)])
  @@index([productId])
  @@index([userId])
  @@index([slug])
  @@index([category, isPinned(sort: Desc), createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([category, viewCount(sort: Desc)])
  @@index([category, replyCount(sort: Desc)])
  @@index([isAnonymous, userId])
  @@map("forum_threads")
}

model ForumReply {
  id        String   @id @default(cuid())
  threadId  String   @map("thread_id")
  userId    String   @map("user_id")
  body      String // sanitised markdown
  parentId  String?  @map("parent_id")
  upvotes   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  thread   ForumThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   ForumReply?  @relation("NestedReplies", fields: [parentId], references: [id])
  children ForumReply[] @relation("NestedReplies")
  votes    ForumVote[]

  @@index([threadId, createdAt])
  @@index([userId])
  @@index([threadId, parentId, createdAt])
  @@map("forum_replies")
}

model ForumVote {
  id      String @id @default(cuid())
  userId  String @map("user_id")
  replyId String @map("reply_id")
  value   Int    @default(1)

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reply ForumReply @relation(fields: [replyId], references: [id], onDelete: Cascade)

  @@unique([userId, replyId])
  @@map("forum_votes")
}

model ThreadVote {
  id        String   @id @default(cuid())
  threadId  String   @map("thread_id")
  userId    String   @map("user_id")
  value     Int // 1 for upvote, -1 for downvote
  createdAt DateTime @default(now()) @map("created_at")

  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([threadId])
  @@index([userId])
  @@map("thread_votes")
}

// ---------------------------------------------------------------------------
// Phase 6: Guides (CMS Content)
// ---------------------------------------------------------------------------

model Guide {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  excerpt         String?
  body            String // rich content from CMS
  category        GuideCategory
  coverImage      String?       @map("cover_image")
  authorId        String        @map("author_id")
  tags            String[]      @default([])
  productMentions String[]      @default([]) @map("product_mentions") // product IDs mentioned
  seoTitle        String?       @map("seo_title")
  seoDescription  String?       @map("seo_description")
  isPublished     Boolean       @default(false) @map("is_published")
  publishedAt     DateTime?     @map("published_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@index([category, isPublished])
  @@index([authorId])
  @@map("guides")
}

// ---------------------------------------------------------------------------
// Phase 6: User Badges (Reputation)
// ---------------------------------------------------------------------------

model UserBadge {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  badge     BadgeType
  awardedAt DateTime  @default(now()) @map("awarded_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badge])
  @@index([userId])
  @@map("user_badges")
}

// ---------------------------------------------------------------------------
// Phase 7: Thread Following & Notifications
// ---------------------------------------------------------------------------

model ThreadFollower {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  threadId  String   @map("thread_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([userId, threadId])
  @@index([threadId])
  @@map("thread_followers")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  type      NotificationType
  threadId  String?          @map("thread_id")
  replyId   String?          @map("reply_id")
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

enum NotificationType {
  REPLY
  MENTION
  FOLLOW
}

// ---------------------------------------------------------------------------
// Marketplace Enums
// ---------------------------------------------------------------------------

enum MarketplaceListingType {
  SELLING
  LOOKING_FOR
  TRADING
}

enum ItemCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  FOR_PARTS
}

enum Currency {
  GBP
  EUR
  USD
}

enum PricingType {
  FIXED
  NEGOTIABLE
  OPEN_TO_OFFERS
  AUCTION
}

enum ShippingOption {
  LOCAL_PICKUP
  NATIONAL_SHIPPING
  INTERNATIONAL_SHIPPING
}

enum ListingStatus {
  ACTIVE
  RESERVED
  SOLD
  FOUND
  EXPIRED
  REMOVED_BY_MOD
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  WITHDRAWN
}

enum ReportReason {
  SCAM_FRAUDULENT
  PROHIBITED_ITEM
  MISLEADING_DESCRIPTION
  DUPLICATE_LISTING
  OFFENSIVE_CONTENT
}

enum ReportStatus {
  PENDING
  REVIEWED_APPROVED
  REVIEWED_REMOVED
}

enum MarketplaceNotificationType {
  NEW_OFFER
  OFFER_ACCEPTED
  OFFER_REJECTED
  OFFER_EXPIRED
  NEW_MESSAGE
  LISTING_MATCH
  LISTING_EXPIRING_SOON
  LISTING_EXPIRED
  LISTING_REPORTED
  LISTING_REMOVED
  REVIEW_RECEIVED
  PRICE_DROP
}

// ---------------------------------------------------------------------------
// Marketplace Models
// ---------------------------------------------------------------------------

model MarketplaceListing {
  id              String                 @id @default(cuid())
  userId          String                 @map("user_id")
  type            MarketplaceListingType
  title           String
  description     String
  category        String
  condition       ItemCondition?
  price           Decimal?               @db.Decimal(10, 2)
  minimumOffer    Decimal?               @map("minimum_offer") @db.Decimal(10, 2)
  currency        Currency               @default(GBP)
  pricingType     PricingType            @map("pricing_type")
  country         String
  region          String?
  shippingOptions ShippingOption[]       @map("shipping_options")
  discordUsername String?                @map("discord_username")
  productId       String?                @map("product_id")
  imageUrls       String[]               @default([]) @map("image_urls")
  status          ListingStatus          @default(ACTIVE)
  isPremium       Boolean                @default(false) @map("is_premium")
  premiumUntil    DateTime?              @map("premium_until")
  viewCount       Int                    @default(0) @map("view_count")
  wishlistCount   Int                    @default(0) @map("wishlist_count")
  expiresAt       DateTime               @map("expires_at")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  user          User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  product       Product?                  @relation(fields: [productId], references: [id], onDelete: SetNull)
  offers        MarketplaceOffer[]
  messages      MarketplaceMessage[]
  reports       MarketplaceReport[]
  reviews       MarketplaceReview[]
  notifications MarketplaceNotification[]
  wishlistedBy  WishlistedListing[]

  @@index([userId])
  @@index([status, createdAt(sort: Desc)])
  @@index([category])
  @@index([type, status])
  @@index([productId])
  @@index([status, category])
  @@index([status, type])
  @@index([status, condition])
  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
  @@index([category, status, createdAt(sort: Desc)])
  @@index([status, price])
  @@index([status, viewCount(sort: Desc)])
  @@map("marketplace_listings")
}

model MarketplaceOffer {
  id        String      @id @default(cuid())
  listingId String      @map("listing_id")
  userId    String      @map("user_id")
  amount    Decimal     @db.Decimal(10, 2)
  currency  Currency
  message   String?
  status    OfferStatus @default(PENDING)
  expiresAt DateTime    @map("expires_at")
  createdAt DateTime    @default(now()) @map("created_at")

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([userId])
  @@index([listingId, status])
  @@index([userId, status])
  @@map("marketplace_offers")
}

model MarketplaceMessage {
  id             String    @id @default(cuid())
  conversationId String    @map("conversation_id")
  listingId      String    @map("listing_id")
  senderId       String    @map("sender_id")
  recipientId    String    @map("recipient_id")
  body           String
  decryptedBody  String?   @map("decrypted_body")
  isDecrypted    Boolean   @default(false) @map("is_decrypted")
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  listing   MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sender    User               @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User               @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([listingId])
  @@index([senderId])
  @@index([recipientId])
  @@index([senderId, createdAt(sort: Desc)])
  @@index([recipientId, readAt])
  @@index([conversationId, createdAt])
  @@map("marketplace_messages")
}

model MarketplaceReport {
  id         String       @id @default(cuid())
  listingId  String       @map("listing_id")
  reporterId String       @map("reporter_id")
  reason     ReportReason
  details    String?
  status     ReportStatus @default(PENDING)
  reviewedBy String?      @map("reviewed_by")
  reviewedAt DateTime?    @map("reviewed_at")
  createdAt  DateTime     @default(now()) @map("created_at")

  listing  MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reporter User               @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([reporterId, listingId])
  @@index([listingId])
  @@index([status])
  @@map("marketplace_reports")
}

model MarketplaceReview {
  id         String   @id @default(cuid())
  listingId  String   @map("listing_id")
  reviewerId String   @map("reviewer_id")
  sellerId   String   @map("seller_id")
  rating     Int
  body       String?
  createdAt  DateTime @default(now()) @map("created_at")

  listing  MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reviewer User               @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  seller   User               @relation("SellerReviews", fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([reviewerId, listingId])
  @@index([sellerId])
  @@index([listingId])
  @@map("marketplace_reviews")
}

model MarketplaceNotification {
  id          String                      @id @default(cuid())
  userId      String                      @map("user_id")
  type        MarketplaceNotificationType
  listingId   String?                     @map("listing_id")
  referenceId String?                     @map("reference_id")
  message     String
  read        Boolean                     @default(false)
  emailSent   Boolean                     @default(false) @map("email_sent")
  createdAt   DateTime                    @default(now()) @map("created_at")

  user    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing MarketplaceListing? @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("marketplace_notifications")
}

model WishlistedListing {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  listingId String   @map("listing_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User               @relation("WishlistedListings", fields: [userId], references: [id], onDelete: Cascade)
  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@map("wishlisted_listings")
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")

  blocker User @relation("BlockedUsers", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlockedBy", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("user_blocks")
}
